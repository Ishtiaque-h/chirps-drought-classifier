# Generated results: keep curated report artifacts, ignore bulk experiment artifacts
results/**
!results/
!results/README.md
!results/report/
!results/report/**

# Literature: keep indices/notes, ignore downloaded PDFs
literature/papers/**
!literature/papers/
!literature/papers/.gitkeep

# Jupyter noise
**/.ipynb_checkpoints/

# Python build/cache
__pycache__/
*.pyc
*.pyo

