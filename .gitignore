# Data (keep structure, ignore generated/downloaded contents)
data/**
!data/
!data/.gitkeep
!data/raw/
!data/processed/
!data/raw/.gitkeep
!data/processed/.gitkeep

# Runtime outputs (models, figures, one-off scores)
outputs/**
